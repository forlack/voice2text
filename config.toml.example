# Voice2Text Configuration
# Copy this file to config.toml to add custom models.
#
# Each [[models]] entry adds a model to the picker.
# Required fields: name, onnx_asr_name
# Optional fields: description, size_hint, repo_id, language
#
# Find compatible models at:
#   https://huggingface.co/istupakov
#   https://github.com/istupakov/onnx-asr

# Example: Add Whisper Base (99+ languages, ~107 MB)
# [[models]]
# name = "whisper-base"
# onnx_asr_name = "whisper-base"
# description = "99+ Languages – OpenAI Whisper Base"
# size_hint = "~107 MB"
# repo_id = "istupakov/whisper-base-onnx"

# Example: Add Canary 1B v2 (25 languages + translation, ~1 GB)
# [[models]]
# name = "canary-1b-v2"
# onnx_asr_name = "nemo-canary-1b-v2"
# description = "25 Languages + Translation – Canary 1B v2"
# size_hint = "~1 GB"
# repo_id = "istupakov/canary-1b-v2-onnx"
# language = "en"

# ── Interactive Mode ──────────────────────────────────────────────────
# How long to wait for silence before triggering a transcription segment.
# Lower = more responsive but may split mid-sentence. Default: 0.5
# [interactive]
# silence_seconds = 0.5

# ── Post-Processing ──────────────────────────────────────────────────
# Grammar correction via an external LLM CLI tool (press 'g' after transcription).
# Default command: claude -p "<prompt>\n\n<text>"
# Any CLI tool that accepts a -p flag with a prompt string works.
# [post_processing]
# command = "claude"
# prompt = "Fix grammar, punctuation, and capitalization in this voice transcription. Return only the corrected text, nothing else."
